<?xml version="1.0" encoding="utf-8"?>
<manifest package="com.nick.myrecoverytracker"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application tools:node="merge">
        <service
            android:name=".ForegroundUnlockService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync" />
        <service
            android:name=".LocationCaptureService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="location|dataSync" />
        <receiver
            android:name=".DebugExportReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.nick.myrecoverytracker.ACTION_DEBUG_EXPORT" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
